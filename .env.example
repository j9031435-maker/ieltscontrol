# Postgres connection strings (e.g. from Neon: https://neon.tech)
# DATABASE_URL = pooled connection (used by the app at runtime)
# DIRECT_URL   = direct/unpooled connection (used by Prisma Migrate)
DATABASE_URL=""
DIRECT_URL=""

# NextAuth — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Anthropic — get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
