// Prisma schema — IELTS Control

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Section {
  READING
  LISTENING
  WRITING
  SPEAKING
}

enum QuestionType {
  MCQ
  TRUE_FALSE_NG
  FILL_BLANK
  MATCHING
}

enum WritingTaskType {
  TASK1
  TASK2
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  attempts Attempt[]
}

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  createdAt DateTime @default(now())
}

model Test {
  id          String   @id @default(cuid())
  section     Section
  title       String
  description String?
  // Reading: full passage text. Listening: script read aloud via TTS.
  bodyText    String
  createdAt   DateTime @default(now())

  questions Question[]
}

model Question {
  id            String       @id @default(cuid())
  testId        String
  order         Int
  type          QuestionType
  promptText    String
  options       String? // JSON-encoded array of strings, for MCQ/MATCHING
  correctAnswer String // plain string, or JSON-encoded for MATCHING

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model WritingTask {
  id        String          @id @default(cuid())
  title     String
  taskType  WritingTaskType
  prompt    String
  minWords  Int             @default(150)
  createdAt DateTime        @default(now())
}

model SpeakingTask {
  id          String   @id @default(cuid())
  title       String
  part        Int // 1, 2, or 3
  promptText  String
  followUps   String? // JSON-encoded array of follow-up questions
  createdAt   DateTime @default(now())
}

model Attempt {
  id          String   @id @default(cuid())
  userId      String
  section     Section
  refId       String // Test.id, WritingTask.id, or SpeakingTask.id
  refTitle    String
  answers     String? // JSON-encoded user answers/transcript
  rawScore    Int? // correct count, for Reading/Listening
  totalScore  Int? // total questions, for Reading/Listening
  bandScore   Float // 0-9 in 0.5 steps
  aiCriteria  String? // JSON-encoded per-criterion bands, for Writing/Speaking
  aiFeedback  String? // free-text feedback, for Writing/Speaking
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
